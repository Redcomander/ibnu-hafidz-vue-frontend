RewriteEngine On

# Tandai request API agar bisa dipasang header no-cache
RewriteCond %{REQUEST_URI} ^/api/
RewriteRule ^ - [E=IS_API:1]

# Proxy request API ke proses backend (ubah port bila diperlukan)
RewriteCond %{REQUEST_URI} ^/api/ [OR]
RewriteCond %{REQUEST_URI} ^/uploads/
RewriteRule ^(api|uploads)/(.*)$ http://127.0.0.1:18080/$1/$2 [P,L]

# Aturan cache:
# - index.html jangan di-cache agar rilis terbaru langsung terbaca
# - /api jangan di-cache agar data selalu fresh
# - aset statis boleh cache lama (file Vite sudah pakai hash nama file)
<IfModule mod_headers.c>
	<Files "index.html">
		Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
		Header set Pragma "no-cache"
		Header set Expires "0"
	</Files>

	Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0" env=IS_API
	Header always set Pragma "no-cache" env=IS_API
	Header always set Expires "0" env=IS_API

	<FilesMatch "\.(js|css|png|jpg|jpeg|gif|svg|webp|ico|woff|woff2)$">
		Header set Cache-Control "public, max-age=31536000, immutable"
	</FilesMatch>
</IfModule>

# Fallback SPA Vite
RewriteCond %{REQUEST_URI} !^/assets/
RewriteCond %{REQUEST_URI} !\.(js|css|map|json|png|jpg|jpeg|gif|svg|webp|ico|woff|woff2)$ [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]
